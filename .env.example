# ERPSight — Local environment configuration
# Copy from .env.example and fill in real values.
# This file is gitignored — never commit it.

# ── Odoo connection ───────────────────────────────────────────────────────────
ODOO_URL=http://educare-connect.me
ODOO_DB=erpsight
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_REQUEST_TIMEOUT=30
ODOO_MAX_RETRIES=3

# ── AI / LLM (leave empty until AI team configures) ──────────────────────────
GEMINI_API_KEY=

# ── Firebase (leave empty until AI team configures) ───────────────────────────
FIREBASE_CREDENTIALS_PATH=
FIREBASE_DATABASE_URL=

# ── Detection thresholds ──────────────────────────────────────────────────────
ZSCORE_THRESHOLD=2.5
CONFIDENCE_THRESHOLD=0.85
MIN_DAYS_OF_STOCK=3
MARGIN_RISK_THRESHOLD=0.05
CHURN_OVERDUE_FACTOR=1.5

# ── Scheduler ─────────────────────────────────────────────────────────────────
POLLING_INTERVAL_MINUTES=15

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
