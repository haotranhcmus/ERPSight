# ERPSight — Template cấu hình môi trường
# Sao chép file này thành .env và điền giá trị thực.
# File .env đã được gitignore — không commit lên repository.

# ── Odoo connection ───────────────────────────────────────────────────────────
ODOO_URL=http://your-odoo-instance.com
ODOO_DB=your_database_name
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password
ODOO_REQUEST_TIMEOUT=30
ODOO_MAX_RETRIES=3

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Gemini API key — dùng cho InsightAgent (phân tích nguyên nhân + đề xuất)
GEMINI_API_KEY=

# ── Firebase ──────────────────────────────────────────────────────────────────
# Đường dẫn đến file service-account JSON của Firebase project
FIREBASE_CREDENTIALS_PATH=
# URL Realtime Database (ví dụ: https://your-project-default-rtdb.firebaseio.com)
FIREBASE_DATABASE_URL=

# ── Detection thresholds ──────────────────────────────────────────────────────
# Z-score ngưỡng phát hiện bất thường doanh thu (mặc định 2.5)
ZSCORE_THRESHOLD=2.5
# Ngưỡng confidence tối thiểu để đưa sự kiện vào báo cáo (0-1)
CONFIDENCE_THRESHOLD=0.85
# Số ngày tồn kho tối thiểu trước khi cảnh báo stockout
MIN_DAYS_OF_STOCK=3
# Ngưỡng tỉ lệ biên lợi nhuận để cảnh báo margin risk (0-1)
MARGIN_RISK_THRESHOLD=0.05
# Hệ số nhân số ngày trễ để phát hiện churn khách VIP (cao hơn = ít nhạy hơn)
CHURN_OVERDUE_FACTOR=1.5

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Tần suất tự động chạy pipeline (phút)
POLLING_INTERVAL_MINUTES=15

# ── Logging ───────────────────────────────────────────────────────────────────
# Mức log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
